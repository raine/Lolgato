#!/usr/bin/env bash
set -euo pipefail

skip_notarization=false
for arg in "$@"; do
	case $arg in
	--skip-notarization)
		skip_notarization=true
		;;
	esac
done

project_dir=$(git rev-parse --show-toplevel)
project_name="Lolgato"
scheme_name="Lolgato"
configuration="Release"
archive_path="$project_dir/build/$project_name.xcarchive"
export_path="$project_dir/build"

cd "$project_dir" || exit 1
mkdir -p "$export_path"

xcodebuild archive \
	-project "$project_name.xcodeproj" \
	-scheme "$scheme_name" \
	-configuration "$configuration" \
	-archivePath "$archive_path" \
	-arch arm64 \
	-arch x86_64 \
	ONLY_ACTIVE_ARCH=NO

cat <<EOF >export_options.plist
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>developer-id</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>teamID</key>
    <string>${APPLE_TEAM_ID}</string>
</dict>
</plist>
EOF

xcodebuild -exportArchive -archivePath "$archive_path" -exportPath "$export_path" -exportOptionsPlist export_options.plist

rm export_options.plist
rm -rf "$archive_path"

app_path="$export_path/$project_name.app"
zip_path="$export_path/$project_name.zip"

if [ "$skip_notarization" = true ]; then
	echo "Build complete. App available at $app_path (notarization skipped)"
else
	# Zip the app for notarization
	echo "Creating zip for notarization..."
	ditto -c -k --keepParent "$app_path" "$zip_path"

	# Notarize the app
	echo "Submitting for notarization..."
	xcrun notarytool submit "$zip_path" --keychain-profile "notarytool" --wait

	# Staple the notarization ticket to the original app
	echo "Stapling notarization ticket..."
	xcrun stapler staple "$app_path"

	# Clean up zip
	rm "$zip_path"

	echo "Build complete. Notarized app available at $app_path"
fi
